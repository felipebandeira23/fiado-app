# Copie este arquivo para .env e preencha os valores

SECRET_KEY=substitua-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Banco de dados ────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > Database > Connection String
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres

# ── Supabase Storage (arquivos de mídia — fotos e QR codes) ──────────────────
# Deixe SUPABASE_S3_KEY_ID em branco para usar disco local em desenvolvimento.
# Preencha TODAS as variáveis abaixo para usar o Supabase Storage em produção.
#
# Como configurar:
#   1. Supabase Dashboard → Storage → New Bucket
#      - Nome: media
#      - Marcar como "Public bucket"
#   2. Storage → S3 Access Keys → New access key
#      - Copie Access Key ID → SUPABASE_S3_KEY_ID
#      - Copie Secret Access Key → SUPABASE_S3_SECRET
#   3. Encontre seu Project Reference em: Project Settings → General → Reference ID
#
SUPABASE_S3_KEY_ID=
SUPABASE_S3_SECRET=
SUPABASE_S3_BUCKET=media
SUPABASE_S3_ENDPOINT=https://[SEU_PROJECT_REF].supabase.co/storage/v1/s3
SUPABASE_S3_PUBLIC_DOMAIN=[SEU_PROJECT_REF].supabase.co/storage/v1/object/public/media
