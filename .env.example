# Copie este arquivo para .env e preencha os valores

SECRET_KEY=substitua-por-uma-chave-secreta-longa-e-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Banco de dados ────────────────────────────────────────────────────────────
# Encontre em: Supabase Dashboard > Project Settings > Database > Connection Parameters
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=[SUA_SENHA]
DB_HOST=db.[SEU_PROJETO].supabase.co
DB_PORT=5432

# ── Supabase Storage (arquivos de mídia — fotos e QR codes) ──────────────────
# Deixe SUPABASE_S3_KEY_ID em branco para usar disco local em desenvolvimento.
# Preencha TODAS as variáveis abaixo para usar o Supabase Storage em produção.
#
# Como configurar:
#   1. Supabase Dashboard → Storage → New Bucket
#      - Nome: media
#      - Marcar como "Public bucket"
#   2. Storage → S3 Access Keys → New access key
#      - Copie Access Key ID → SUPABASE_S3_KEY_ID
#      - Copie Secret Access Key → SUPABASE_S3_SECRET
#   3. Encontre seu Project Reference em: Project Settings → General → Reference ID
#
SUPABASE_S3_KEY_ID=
SUPABASE_S3_SECRET=
SUPABASE_S3_BUCKET=media
SUPABASE_S3_ENDPOINT=https://[SEU_PROJECT_REF].supabase.co/storage/v1/s3
SUPABASE_S3_PUBLIC_DOMAIN=[SEU_PROJECT_REF].supabase.co/storage/v1/object/public/media

# ── E-mail (para recuperação de senha) ───────────────────────────────────────
# Em desenvolvimento, o valor "console" imprime o e-mail no terminal.
# Em produção, use "django.core.mail.backends.smtp.EmailBackend" e configure as variáveis abaixo.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=App de Fiado <noreply@fiadoapp.com>

# ── WhatsApp (notificações ao cliente) ────────────────────────────────────────
# Deixe WHATSAPP_PROVIDER vazio para desabilitar as notificações.
# Opção 1: Z-API (recomendado para Brasil — https://z-api.io)
WHATSAPP_PROVIDER=
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
# Opção 2: Twilio WhatsApp
# WHATSAPP_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=whatsapp:+5511999999999
